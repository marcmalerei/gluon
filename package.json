{
  "name": "@gluonjs/core",
  "version": "0.0.0",
  "description": "A native-first UI system built on Custom Elements, HTML template literals, and adopted stylesheets.",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marcmalerei/gluon.git"
  },
  "homepage": "https://github.com/marcmalerei/gluon#readme",
  "bugs": {
    "url": "https://github.com/marcmalerei/gluon/issues"
  },
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "sideEffects": false,
  "engines": {
    "node": "^22.12.0 || ^24.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles": {
      "types": "./dist/types/styles/index.d.ts",
      "import": "./dist/styles.js"
    },
    "./quarks": {
      "types": "./dist/types/quarks/index.d.ts",
      "import": "./dist/quarks.js"
    },
    "./atoms": {
      "types": "./dist/types/atoms/index.d.ts",
      "import": "./dist/atoms.js"
    },
    "./molecules": {
      "types": "./dist/types/molecules/index.d.ts",
      "import": "./dist/molecules.js"
    },
    "./organisms": {
      "types": "./dist/types/organisms/index.d.ts",
      "import": "./dist/organisms.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@gluonjs/reactivity": "0.0.0"
  },
  "scripts": {
    "build": "npm run build:core && npm run build:router && npm run build:store && npm run build:ssr && npm run build:compiler && npm run build:vite && npm run build:test-utils && npm run build:shop",
    "build:core": "npm run build:reactivity && vite build && tsc -p tsconfig.build.json",
    "build:reactivity": "npm run build --workspace @gluonjs/reactivity",
    "build:router": "npm run build --workspace @gluonjs/router",
    "build:store": "npm run build --workspace @gluonjs/store",
    "build:ssr": "npm run build --workspace @gluonjs/ssr",
    "build:compiler": "npm run build --workspace @gluonjs/compiler",
    "build:vite": "npm run build --workspace @gluonjs/vite",
    "build:test-utils": "npm run build --workspace @gluonjs/test-utils",
    "build:shop": "vite build --config examples/shop/vite.config.ts",
    "dev:shop": "vite --config examples/shop/vite.config.ts",
    "dev:benchmark": "vite --config benchmarks/rendering/vite.config.ts",
    "measure:shop": "npm run build:shop && node scripts/measure-shop-build.mjs",
    "typecheck": "npm run typecheck:core && npm run typecheck:reactivity && npm run typecheck:router && npm run typecheck:store && npm run typecheck:ssr && npm run typecheck:compiler && npm run typecheck:vite && npm run typecheck:test-utils",
    "typecheck:core": "tsc -p tsconfig.json --noEmit",
    "typecheck:reactivity": "npm run typecheck --workspace @gluonjs/reactivity",
    "typecheck:router": "npm run typecheck --workspace @gluonjs/router",
    "typecheck:store": "npm run typecheck --workspace @gluonjs/store",
    "typecheck:ssr": "npm run typecheck --workspace @gluonjs/ssr",
    "typecheck:compiler": "npm run typecheck --workspace @gluonjs/compiler",
    "typecheck:vite": "npm run typecheck --workspace @gluonjs/vite",
    "typecheck:test-utils": "npm run typecheck --workspace @gluonjs/test-utils",
    "typecheck:reactivity-api": "tsc -p tests-node/tsconfig.reactivity-types.json",
    "typecheck:core-api": "tsc -p tests-node/tsconfig.core-types.json",
    "typecheck:router-api": "tsc -p tests-node/tsconfig.router-types.json",
    "typecheck:store-api": "tsc -p tests-node/tsconfig.store-types.json",
    "typecheck:test-utils-api": "tsc -p tests-node/tsconfig.test-utils-types.json",
    "typecheck:tooling-api": "tsc -p tests-node/tsconfig.tooling-types.json",
    "typecheck:ssr-api": "tsc -p tests-node/tsconfig.ssr-types.json",
    "test": "npm run test:browser && npm run test:reactivity && npm run test:router && npm run test:store && npm run test:ssr && npm run test:vite && npm run test:test-utils",
    "test:browser": "vitest run",
    "test:reactivity": "vitest run --config vitest.reactivity.config.ts",
    "test:router": "vitest run --config vitest.router.config.ts",
    "test:store": "vitest run --config vitest.store.config.ts",
    "test:ssr": "vitest run --config vitest.ssr.config.ts",
    "test:vite": "vitest run --config vitest.vite.config.ts",
    "test:test-utils": "vitest run --config vitest.test-utils.config.ts",
    "test:coverage": "npm run test:browser:coverage && npm run test:reactivity:coverage && npm run test:router:coverage && npm run test:router-browser:coverage && npm run test:store:coverage && npm run test:ssr:coverage && npm run test:vite:coverage && npm run test:test-utils:coverage",
    "test:browser:coverage": "vitest run --coverage",
    "test:reactivity:coverage": "vitest run --config vitest.reactivity.config.ts --coverage",
    "test:router:coverage": "vitest run --config vitest.router.config.ts --coverage",
    "test:router-browser:coverage": "vitest run --config vitest.router-browser.config.ts --coverage",
    "test:store:coverage": "vitest run --config vitest.store.config.ts --coverage",
    "test:ssr:coverage": "vitest run --config vitest.ssr.config.ts --coverage",
    "test:vite:coverage": "vitest run --config vitest.vite.config.ts --coverage",
    "test:test-utils:coverage": "vitest run --config vitest.test-utils.config.ts --coverage",
    "test:watch": "vitest",
    "benchmark:keyed": "vitest bench --run benchmarks/keyed-list.bench.ts",
    "benchmark:rendering": "node scripts/run-rendering-benchmark.mjs",
    "check:router-lazy": "node scripts/validate-router-lazy-build.mjs",
    "check:shop-boundaries": "node scripts/validate-shop-boundaries.mjs",
    "check:packages": "node scripts/validate-package-contract.mjs",
    "check": "npm run typecheck && npm run check:shop-boundaries && npm run test:coverage && npm run build && npm run typecheck:core-api && npm run typecheck:reactivity-api && npm run typecheck:router-api && npm run typecheck:store-api && npm run typecheck:test-utils-api && npm run typecheck:tooling-api && npm run typecheck:ssr-api && npm run check:router-lazy && npm run check:packages"
  },
  "devDependencies": {
    "@jridgewell/trace-mapping": "^0.3.31",
    "@types/node": "^22.10.0",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.1.10",
    "lit": "3.3.3",
    "lit-html": "3.3.3",
    "playwright": "^1.58.2",
    "typescript": "^5.7.0",
    "vite": "^8.1.4",
    "vitest": "^4.0.18",
    "vue": "3.5.39"
  }
}
