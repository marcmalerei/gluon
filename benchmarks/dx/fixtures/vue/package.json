{
  "name": "vue",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run type-check && npm run build-only && vite build --ssr src/entry-server.ts --outDir dist-server",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "diagnostics": "vue-tsc --noEmit -p diagnostics/tsconfig.json",
    "dev:ssr": "node server.mjs",
    "build-only": "vite build",
    "type-check": "vue-tsc --build"
  },
  "dependencies": {
    "@vue/server-renderer": "3.5.39",
    "pinia": "3.0.4",
    "vue": "3.5.39",
    "vue-router": "5.1.0"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tsconfig/node24": "24.0.4",
    "@types/node": "24.13.2",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/tsconfig": "0.9.1",
    "typescript": "5.9.3",
    "vite": "8.1.4",
    "vue-tsc": "3.3.7"
  },
  "engines": {
    "node": "^22.18.0 || >=24.12.0"
  }
}
