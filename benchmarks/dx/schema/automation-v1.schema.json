{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/marcmalerei/gluon/benchmarks/dx/schema/automation-v1.schema.json",
  "title": "Gluon DX non-human automation evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "specification", "status", "runId", "sourceCommit", "startedAt", "finishedAt", "environment", "frameworks", "tasks", "humanPasses", "blockers"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "specification": { "const": "benchmarks/dx/specification-v1.json" },
    "status": { "const": "automated-only" },
    "runId": { "type": "string", "minLength": 1 },
    "sourceCommit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "startedAt": { "type": "string", "format": "date-time" },
    "finishedAt": { "type": "string", "format": "date-time" },
    "environment": {
      "type": "object", "additionalProperties": false,
      "required": ["operatingSystem", "architecture", "node", "packageManager", "playwright", "browsers"],
      "properties": {
        "operatingSystem": { "type": "string", "minLength": 1 }, "architecture": { "type": "string", "minLength": 1 },
        "node": { "type": "string", "minLength": 1 }, "packageManager": { "type": "string", "minLength": 1 }, "playwright": { "type": "string", "minLength": 1 },
        "browsers": {
          "type": "object", "additionalProperties": false, "required": ["chromium", "firefox", "webkit"],
          "properties": { "chromium": { "type": "string", "minLength": 1 }, "firefox": { "type": "string", "minLength": 1 }, "webkit": { "type": "string", "minLength": 1 } }
        }
      }
    },
    "frameworks": { "type": "array", "minItems": 3, "maxItems": 3, "items": { "$ref": "#/$defs/framework" } },
    "tasks": { "type": "array", "minItems": 21, "maxItems": 21, "items": { "$ref": "#/$defs/task" } },
    "humanPasses": { "type": "array", "maxItems": 0 },
    "blockers": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
  },
  "$defs": {
    "checkStatus": { "enum": ["pass", "fail", "not-applicable", "platform-limitation"] },
    "command": {
      "type": "object", "additionalProperties": false, "required": ["command", "exitCode", "expectedExit", "durationMs", "stdout", "stderr"],
      "properties": { "command": { "type": "string" }, "exitCode": { "type": "integer" }, "expectedExit": { "enum": ["zero", "nonzero"] }, "durationMs": { "type": "integer", "minimum": 0 }, "stdout": { "type": "string" }, "stderr": { "type": "string" } }
    },
    "framework": {
      "type": "object", "additionalProperties": false, "required": ["id", "lane", "versions", "scaffoldCommand", "interactiveAnswers", "fixture", "lockfile", "commands"],
      "properties": { "id": { "enum": ["gluon", "vue", "react"] }, "lane": { "type": "string" }, "versions": { "type": "object", "minProperties": 1, "additionalProperties": { "type": "string" } }, "scaffoldCommand": { "type": "string" }, "interactiveAnswers": { "type": "array", "items": { "type": "string" } }, "fixture": { "type": "string" }, "lockfile": { "type": "string" }, "commands": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/command" } } }
    },
    "task": {
      "type": "object", "additionalProperties": false, "required": ["framework", "taskId", "status", "commands", "generatedFiles", "authorCreatedFiles", "authorSourceLines", "configurationLines", "productionDependencies", "developmentDependencies", "publicApis", "frameworkConcepts", "checks", "diagnostics", "browserVisibleOutput", "evidence", "limitations"],
      "properties": {
        "framework": { "enum": ["gluon", "vue", "react"] }, "taskId": { "type": "string", "pattern": "^T[1-7]-[a-z-]+$" }, "status": { "enum": ["pass", "platform-limitation", "fail"] },
        "commands": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/command" } },
        "generatedFiles": { "type": "array", "items": { "type": "string" } }, "authorCreatedFiles": { "type": "array", "items": { "type": "string" } },
        "authorSourceLines": { "type": "integer", "minimum": 0 }, "configurationLines": { "type": "integer", "minimum": 0 },
        "productionDependencies": { "type": "array", "items": { "type": "string" } }, "developmentDependencies": { "type": "array", "items": { "type": "string" } },
        "publicApis": { "type": "array", "minItems": 1, "items": { "type": "string" } }, "frameworkConcepts": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "checks": {
          "type": "object", "additionalProperties": false, "required": ["typecheck", "build", "browserTest", "accessibility", "hmr", "ssr", "hydration", "cleanup"],
          "properties": { "typecheck": { "$ref": "#/$defs/checkStatus" }, "build": { "$ref": "#/$defs/checkStatus" }, "browserTest": { "$ref": "#/$defs/checkStatus" }, "accessibility": { "$ref": "#/$defs/checkStatus" }, "hmr": { "$ref": "#/$defs/checkStatus" }, "ssr": { "$ref": "#/$defs/checkStatus" }, "hydration": { "$ref": "#/$defs/checkStatus" }, "cleanup": { "$ref": "#/$defs/checkStatus" } }
        },
        "diagnostics": { "type": "array", "items": { "type": "string" } }, "browserVisibleOutput": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "evidence": { "type": "array", "minItems": 1, "items": { "type": "string" } }, "limitations": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
