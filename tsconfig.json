{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@gluonjs/compiler": ["packages/compiler/src/index.ts"],
      "@gluonjs/compiler/diagnostics": ["packages/compiler/src/diagnostics.ts"],
      "@gluonjs/core": ["src/index.ts"],
      "@gluonjs/core/decorators": ["src/decorators.ts"],
      "@gluonjs/quarks": ["packages/quarks/src/index.ts"],
      "@gluonjs/atoms": ["packages/atoms/src/index.ts"],
      "@gluonjs/molecules": ["packages/molecules/src/index.ts"],
      "@gluonjs/organisms": ["packages/organisms/src/index.ts"],
      "@gluonjs/devtools": ["packages/devtools/src/index.ts"],
      "@gluonjs/devtools-api": ["packages/devtools-api/src/index.ts"],
      "@gluonjs/language-server": ["packages/language-server/src/index.ts"],
      "@gluonjs/vue-migration-analyzer": ["packages/vue-migration-analyzer/src/index.ts"],
      "@gluonjs/vue-migration-analyzer/schema": ["packages/vue-migration-analyzer/src/schema.ts"],
      "@gluonjs/reactivity": ["packages/reactivity/src/index.ts"],
      "@gluonjs/router": ["packages/router/src/index.ts"],
      "@gluonjs/router/memory": ["packages/router/src/memory.ts"],
      "@gluonjs/ssr": ["packages/ssr/src/index.ts"],
      "@gluonjs/ssr/hydration": ["packages/ssr/src/hydration.ts"],
      "@gluonjs/ssr/static": ["packages/ssr/src/static.ts"],
      "@gluonjs/ssr/streaming": ["packages/ssr/src/streaming.ts"],
      "@gluonjs/store": ["packages/store/src/index.ts"],
      "@gluonjs/test-utils": ["packages/test-utils/src/index.ts"],
      "@gluonjs/test-utils/ssr": ["packages/test-utils/src/ssr.ts"],
      "@gluonjs/vite": ["packages/vite/src/index.ts"]
    },
    "types": ["node"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "useDefineForClassFields": true
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "tests-node/reactivity.spec.ts",
    "benchmarks/**/*.ts",
    "examples/**/*.ts",
    "docs-site/examples/*.d.ts",
    "vite.config.ts",
    "vitest.reactivity.config.ts",
    "vitest.ssr.config.ts",
    "vitest.store.config.ts",
    "vitest.test-utils.config.ts",
    "vitest.vite.config.ts",
    "vitest.vue-analyzer.config.ts"
  ],
  "exclude": ["benchmarks/dx/fixtures"]
}
