{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/marcmalerei/gluon/blob/main/release/compatibility-manifest.schema.json",
  "title": "Gluon immutable release compatibility manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "releaseVersion",
    "sourceCommit",
    "cutAt",
    "automatedQualityRun",
    "browserTargets",
    "nodeTargets",
    "surfaces"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "releaseVersion": { "type": "string", "pattern": "^[1-9][0-9]*\\.[0-9]+\\.[0-9]+$" },
    "sourceCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "cutAt": { "type": "string", "format": "date-time" },
    "automatedQualityRun": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "conclusion"],
      "properties": {
        "url": { "type": "string", "format": "uri", "pattern": "^https://github.com/marcmalerei/gluon/actions/runs/[0-9]+$" },
        "conclusion": { "const": "success" }
      }
    },
    "browserTargets": {
      "type": "array",
      "minItems": 11,
      "items": { "$ref": "#/$defs/browserTarget" }
    },
    "nodeTargets": {
      "type": "array",
      "minItems": 2,
      "items": { "$ref": "#/$defs/nodeTarget" }
    },
    "surfaces": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/surface" }
    }
  },
  "$defs": {
    "browserTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "product", "productVersion", "engine", "engineVersion", "operatingSystem", "device", "mode", "evidence", "outcome"],
      "properties": {
        "id": {
          "enum": [
            "chrome-desktop-stable",
            "chrome-desktop-previous",
            "edge-desktop-stable",
            "edge-desktop-previous",
            "firefox-desktop-stable",
            "firefox-desktop-previous",
            "firefox-desktop-esr",
            "safari-macos-stable",
            "safari-macos-previous",
            "safari-ios-stable",
            "safari-ios-previous",
            "chrome-android-stable",
            "firefox-android-stable"
          ]
        },
        "product": { "type": "string", "minLength": 1 },
        "productVersion": { "type": "string", "minLength": 1 },
        "engine": { "type": "string", "minLength": 1 },
        "engineVersion": { "type": "string", "minLength": 1 },
        "operatingSystem": { "type": "string", "minLength": 1 },
        "device": { "type": "string", "minLength": 1 },
        "mode": { "enum": ["headed-automated", "headed-manual"] },
        "evidence": { "type": "array", "minItems": 1, "items": { "type": "string", "format": "uri", "pattern": "^https://" } },
        "outcome": { "const": "pass" }
      }
    },
    "nodeTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "releaseStatus", "evidence", "outcome"],
      "properties": {
        "id": { "enum": ["node-22-lts", "node-24-lts"] },
        "version": { "type": "string", "pattern": "^(22|24)\\.[0-9]+\\.[0-9]+$" },
        "releaseStatus": { "enum": ["active-lts", "maintenance-lts"] },
        "evidence": { "type": "array", "minItems": 1, "items": { "type": "string", "format": "uri", "pattern": "^https://" } },
        "outcome": { "const": "pass" }
      }
    },
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "evidence", "outcome"],
      "properties": {
        "id": { "enum": ["client-rendering", "server-rendering", "streaming", "hydration", "static-generation"] },
        "evidence": { "type": "array", "minItems": 1, "items": { "type": "string", "format": "uri", "pattern": "^https://" } },
        "outcome": { "const": "pass" }
      }
    }
  }
}
