{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/marcmalerei/gluon/blob/main/release/compatibility-manifest.schema.json",
  "title": "Gluon immutable automated compatibility manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "releaseVersion",
    "sourceCommit",
    "cutAt",
    "automatedQualityRun",
    "supportBoundary",
    "engineTargets",
    "nodeTargets",
    "surfaces"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "releaseVersion": { "type": "string", "pattern": "^[1-9][0-9]*\\.[0-9]+\\.[0-9]+$" },
    "sourceCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "cutAt": { "type": "string", "format": "date-time" },
    "automatedQualityRun": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "conclusion"],
      "properties": {
        "url": { "type": "string", "format": "uri", "pattern": "^https://github.com/marcmalerei/gluon/actions/runs/[0-9]+$" },
        "conclusion": { "const": "success" }
      }
    },
    "supportBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "brandedProductSupportClaimed"],
      "properties": {
        "model": { "const": "playwright-engine-and-node-evidence" },
        "brandedProductSupportClaimed": { "const": false }
      }
    },
    "engineTargets": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "$ref": "#/$defs/engineTarget" }
    },
    "nodeTargets": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "$ref": "#/$defs/nodeTarget" }
    },
    "surfaces": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": { "$ref": "#/$defs/surface" }
    }
  },
  "$defs": {
    "engineTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "browserBinary", "browserVersion", "engine", "engineVersion", "runner", "mode", "evidence", "outcome"],
      "properties": {
        "id": { "enum": ["playwright-chromium", "playwright-firefox", "playwright-webkit"] },
        "browserBinary": { "type": "string", "minLength": 1 },
        "browserVersion": { "type": "string", "minLength": 1 },
        "engine": { "type": "string", "minLength": 1 },
        "engineVersion": { "type": "string", "minLength": 1 },
        "runner": { "type": "string", "minLength": 1 },
        "mode": { "const": "headless-automated" },
        "evidence": { "type": "array", "minItems": 1, "items": { "type": "string", "format": "uri", "pattern": "^https://" } },
        "outcome": { "const": "pass" }
      }
    },
    "nodeTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "releaseStatus", "evidence", "outcome"],
      "properties": {
        "id": { "enum": ["node-22-lts", "node-24-lts"] },
        "version": { "type": "string", "pattern": "^(22|24)\\.[0-9]+\\.[0-9]+$" },
        "releaseStatus": { "enum": ["active-lts", "maintenance-lts"] },
        "evidence": { "type": "array", "minItems": 1, "items": { "type": "string", "format": "uri", "pattern": "^https://" } },
        "outcome": { "const": "pass" }
      }
    },
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "evidence", "outcome"],
      "properties": {
        "id": { "enum": ["client-rendering", "server-rendering", "streaming", "hydration", "static-generation"] },
        "evidence": { "type": "array", "minItems": 1, "items": { "type": "string", "format": "uri", "pattern": "^https://" } },
        "outcome": { "const": "pass" }
      }
    }
  }
}
