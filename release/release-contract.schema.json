{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/marcmalerei/gluon/blob/main/release/release-contract.schema.json",
  "title": "Gluon release contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "releaseGroup",
    "targetVersion",
    "tagPrefix",
    "environment",
    "artifactDirectory",
    "manualEvidencePath",
    "compatibilityManifestPath",
    "bootstrap",
    "spdxSchema",
    "artifacts",
    "publication",
    "externalPrerequisites"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "releaseGroup": { "const": "gluon-framework" },
    "targetVersion": { "type": "string", "pattern": "^[1-9][0-9]*\\.[0-9]+\\.[0-9]+$" },
    "tagPrefix": { "const": "v" },
    "environment": { "const": "npm" },
    "artifactDirectory": { "const": ".tmp/release" },
    "manualEvidencePath": { "const": "release/evidence/{version}.json" },
    "compatibilityManifestPath": { "const": "release/compatibility/{version}.json" },
    "bootstrap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "artifactDirectory", "distTag", "access", "identity", "latestPolicy", "supersededRecords", "packageFiles"],
      "properties": {
        "version": { "const": "0.0.0-bootstrap.1" },
        "artifactDirectory": { "const": ".tmp/npm-bootstrap" },
        "distTag": { "const": "gluon-bootstrap" },
        "access": { "const": "public" },
        "identity": { "const": "owner-interactive-2fa" },
        "latestPolicy": { "const": "absent-or-reviewed-bootstrap-until-first-supported-release" },
        "supersededRecords": {
          "type": "array",
          "prefixItems": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["name", "version", "integrity", "shasum"],
              "properties": {
                "name": { "const": "@gluonjs/reactivity" },
                "version": { "const": "0.0.0-bootstrap.0" },
                "integrity": { "const": "sha512-/WfS45xyarkObJanK4IbQsyznDR60Fte+mvik1mh2SUm29D/ns1tqrQs2b21FYdjAQFyq62z0WDENNBDJ4472w==" },
                "shasum": { "const": "9a1ca1af75878ea5aebba3ac6139ac0beee3273b" }
              }
            }
          ],
          "items": false
        },
        "packageFiles": {
          "type": "array",
          "prefixItems": [
            { "const": "package.json" },
            { "const": "README.md" },
            { "const": "LICENSE" }
          ],
          "items": false
        }
      }
    },
    "spdxSchema": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "source", "sourceCommit", "sha256"],
      "properties": {
        "path": { "const": "release/spdx-2.3.schema.json" },
        "source": { "type": "string", "format": "uri", "pattern": "^https://raw\\.githubusercontent\\.com/spdx/spdx-spec/[a-f0-9]{40}/schemas/spdx-schema\\.json$" },
        "sourceCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packageArchives",
        "canonicalPackageDigests",
        "aggregateSbomFormats",
        "perPackageSbomFormats",
        "checksums",
        "releaseEvidence"
      ],
      "properties": {
        "packageArchives": { "const": true },
        "canonicalPackageDigests": { "const": true },
        "aggregateSbomFormats": {
          "type": "array",
          "prefixItems": [{ "const": "spdx-2.3" }, { "const": "cyclonedx-1.7" }],
          "items": false
        },
        "perPackageSbomFormats": {
          "type": "array",
          "prefixItems": [{ "const": "spdx-2.3" }, { "const": "cyclonedx-1.7" }],
          "items": false
        },
        "checksums": { "const": "sha256" },
        "releaseEvidence": { "const": true }
      }
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["registry", "access", "provenance", "distTag", "stagingDistTagPrefix", "promotion", "identity", "longLivedTokenAllowed"],
      "properties": {
        "registry": { "const": "https://registry.npmjs.org" },
        "access": { "const": "public" },
        "provenance": { "const": true },
        "distTag": { "const": "latest" },
        "stagingDistTagPrefix": { "const": "gluon-staging-v" },
        "promotion": { "const": "interactive-2fa" },
        "identity": { "const": "npm-trusted-publishing" },
        "longLivedTokenAllowed": { "const": false }
      }
    },
    "externalPrerequisites": {
      "type": "array",
      "minItems": 10,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
