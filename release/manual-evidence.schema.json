{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/marcmalerei/gluon/blob/main/release/manual-evidence.schema.json",
  "title": "Gluon release-cut manual evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "releaseVersion",
    "testedCommit",
    "cutAt",
    "automatedQualityRun",
    "browserDeviceRows",
    "assistiveTechnologyRows",
    "approvedBy",
    "approvedAt"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "releaseVersion": { "type": "string", "pattern": "^[1-9][0-9]*\\.[0-9]+\\.[0-9]+$" },
    "testedCommit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "cutAt": { "type": "string", "format": "date-time" },
    "automatedQualityRun": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "conclusion"],
      "properties": {
        "url": { "type": "string", "format": "uri", "pattern": "^https://github.com/marcmalerei/gluon/actions/runs/" },
        "conclusion": { "const": "success" }
      }
    },
    "browserDeviceRows": {
      "type": "array",
      "minItems": 7,
      "items": { "$ref": "#/$defs/evidenceRow" }
    },
    "assistiveTechnologyRows": {
      "type": "array",
      "minItems": 7,
      "items": { "$ref": "#/$defs/evidenceRow" }
    },
    "approvedBy": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "approvedAt": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "evidenceRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "product",
        "productVersion",
        "engineVersion",
        "operatingSystem",
        "device",
        "mode",
        "input",
        "assistiveTechnology",
        "assistiveTechnologyVersion",
        "executedAt",
        "tester",
        "outcome",
        "artifacts"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "product": { "type": "string", "minLength": 1 },
        "productVersion": { "type": "string", "minLength": 1 },
        "engineVersion": { "type": "string", "minLength": 1 },
        "operatingSystem": { "type": "string", "minLength": 1 },
        "device": { "type": "string", "minLength": 1 },
        "mode": { "enum": ["headed-automated", "headed-manual"] },
        "input": { "type": "string", "minLength": 1 },
        "assistiveTechnology": { "type": ["string", "null"] },
        "assistiveTechnologyVersion": { "type": ["string", "null"] },
        "executedAt": { "type": "string", "format": "date-time" },
        "tester": { "type": "string", "minLength": 1 },
        "outcome": { "const": "pass" },
        "artifacts": { "type": "array", "minItems": 1, "items": { "type": "string", "format": "uri", "pattern": "^https://" } }
      }
    }
  }
}
