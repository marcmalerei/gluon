{
  "name": "@gluonjs/reactivity",
  "version": "1.4.0",
  "description": "DOM-free reactive state primitives for Gluon.",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marcmalerei/gluon.git",
    "directory": "packages/reactivity"
  },
  "homepage": "https://github.com/marcmalerei/gluon/tree/main/packages/reactivity#readme",
  "bugs": {
    "url": "https://github.com/marcmalerei/gluon/issues"
  },
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "engines": {
    "node": "^22.12.0 || ^24.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./signals": {
      "types": "./dist/signals/index.d.ts",
      "import": "./dist/signals/index.js"
    },
    "./preact-signals": {
      "types": "./dist/preact-signals.d.ts",
      "import": "./dist/preact-signals.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "peerDependencies": {
    "@preact/signals-core": ">=1.14.4 <2",
    "signal-polyfill": "0.2.2"
  },
  "peerDependenciesMeta": {
    "@preact/signals-core": {
      "optional": true
    },
    "signal-polyfill": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
