{
  "name": "@gluonjs/test-utils",
  "version": "1.2.0",
  "description": "Black-box component and application test helpers for Gluon.",
  "private": false,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marcmalerei/gluon.git",
    "directory": "packages/test-utils"
  },
  "homepage": "https://github.com/marcmalerei/gluon/tree/main/packages/test-utils#readme",
  "bugs": {
    "url": "https://github.com/marcmalerei/gluon/issues"
  },
  "engines": {
    "node": "^22.12.0 || ^24.0.0"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ssr": {
      "types": "./dist/ssr.d.ts",
      "import": "./dist/ssr.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "peerDependencies": {
    "@gluonjs/core": "1.2.0",
    "@gluonjs/reactivity": "1.2.0",
    "@gluonjs/router": "1.2.0",
    "@gluonjs/ssr": "1.2.0",
    "@gluonjs/store": "1.2.0"
  },
  "peerDependenciesMeta": {
    "@gluonjs/core": {
      "optional": true
    },
    "@gluonjs/ssr": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
