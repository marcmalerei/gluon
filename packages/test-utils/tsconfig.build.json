{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@gluonjs/core": ["dist/types/index.d.ts"],
      "@gluonjs/reactivity": ["packages/reactivity/dist/index.d.ts"],
      "@gluonjs/router": ["packages/router/dist/index.d.ts"],
      "@gluonjs/router/memory": ["packages/router/dist/memory.d.ts"],
      "@gluonjs/ssr": ["packages/ssr/dist/index.d.ts"],
      "@gluonjs/store": ["packages/store/dist/index.d.ts"]
    },
    "sourceMap": true
  }
}
