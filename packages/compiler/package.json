{
  "name": "@gluonjs/compiler",
  "version": "1.2.0",
  "description": "Source transforms and template locations for Gluon tooling.",
  "private": false,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marcmalerei/gluon.git",
    "directory": "packages/compiler"
  },
  "homepage": "https://github.com/marcmalerei/gluon/tree/main/packages/compiler#readme",
  "bugs": {
    "url": "https://github.com/marcmalerei/gluon/issues"
  },
  "engines": {
    "node": "^22.12.0 || ^24.0.0"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./diagnostics": {
      "types": "./dist/diagnostics.d.ts",
      "import": "./dist/diagnostics.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "magic-string": "^0.30.21",
    "typescript": "^5.7.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
