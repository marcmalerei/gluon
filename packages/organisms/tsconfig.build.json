{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@gluonjs/core": [
        "dist/types/index.d.ts"
      ],
      "@gluonjs/quarks": [
        "packages/quarks/dist/index.d.ts"
      ],
      "@gluonjs/atoms": [
        "packages/atoms/dist/index.d.ts"
      ],
      "@gluonjs/molecules": [
        "packages/molecules/dist/index.d.ts"
      ]
    },
    "sourceMap": true
  }
}
