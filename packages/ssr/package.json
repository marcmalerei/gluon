{
  "name": "@gluonjs/ssr",
  "version": "1.4.0",
  "description": "DOM-independent server rendering and request isolation for Gluon.",
  "private": false,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marcmalerei/gluon.git",
    "directory": "packages/ssr"
  },
  "homepage": "https://github.com/marcmalerei/gluon/tree/main/packages/ssr#readme",
  "bugs": {
    "url": "https://github.com/marcmalerei/gluon/issues"
  },
  "engines": {
    "node": "^22.12.0 || ^24.0.0"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./streaming": {
      "types": "./dist/streaming.d.ts",
      "import": "./dist/streaming.js"
    },
    "./hydration": {
      "types": "./dist/hydration.d.ts",
      "import": "./dist/hydration.js"
    },
    "./eleventy": {
      "types": "./dist/eleventy.d.ts",
      "import": "./dist/eleventy.js"
    },
    "./static": {
      "types": "./dist/static.d.ts",
      "import": "./dist/static.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@gluonjs/reactivity": "1.4.0",
    "@gluonjs/router": "1.4.0",
    "@gluonjs/store": "1.4.0"
  },
  "peerDependencies": {
    "@gluonjs/core": "1.4.0"
  },
  "peerDependenciesMeta": {
    "@gluonjs/core": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
